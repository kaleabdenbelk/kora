model Program {
  id            String             @id @default(cuid())
  name          String
  description   String?
  goal          TrainingGoal
  level         ExperienceLevel
  durationWeeks Int
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  isDeleted     Boolean            @default(false)
  phases        Phase[]
  selections    ProgramSelection[]
  userPlans     UserPlan[]

  @@map("programs")
}

model Phase {
  id            String            @id @default(cuid())
  programId     String
  name          String
  order         Int
  durationWeeks Int
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  isDeleted     Boolean           @default(false)
  program       Program           @relation(fields: [programId], references: [id], onDelete: Cascade)
  workouts      WorkoutTemplate[]

  @@map("phases")
}

model WorkoutTemplate {
  id        String             @id @default(cuid())
  phaseId   String
  name      String
  dayNumber Int
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt
  isDeleted Boolean            @default(false)
  exercises ExerciseTemplate[]
  phase     Phase              @relation(fields: [phaseId], references: [id], onDelete: Cascade)

  @@map("workout_templates")
}

model ExerciseTemplate {
  id                String          @id @default(cuid())
  workoutTemplateId String
  exerciseId        String
  order             Int
  sets              Int
  reps              String
  intensity         String?
  restTime          Int?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  isDeleted         Boolean         @default(false)
  exercise          Exercise        @relation(fields: [exerciseId], references: [id])
  workoutTemplate   WorkoutTemplate @relation(fields: [workoutTemplateId], references: [id], onDelete: Cascade)

  @@map("exercise_templates")
}

model ProgramSelection {
  id          String          @id @default(cuid())
  goal        TrainingGoal
  level       ExperienceLevel
  daysPerWeek Int
  gender      Gender
  programId   String
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  isDeleted   Boolean         @default(false)
  program     Program         @relation(fields: [programId], references: [id])

  @@unique([goal, level, daysPerWeek, gender])
  @@map("program_selections")
}
