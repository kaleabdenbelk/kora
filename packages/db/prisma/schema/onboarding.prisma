model Onboarding {
  id                  String               @id @default(cuid())
  userId              String               @unique
  preferredName       String?
  gender              Gender?
  age                 Int?
  weight              Float?
  targetWeight        Float?
  height              Float?
  bmi                 Float?
  bmr                 Float?
  tdee                Float?
  activityLevel       ActivityLevel?
  sleepHours          Float?
  waterDaily          Float?
  trainingLevel       ExperienceLevel?
  trainingEnvironment ExerciseEnvironment?
  trainingDaysPerWeek Int?
  workoutDays         DayOfWeek[]
  goal                TrainingGoal?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  isDeleted           Boolean              @default(false)
  user                User                 @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("onboarding")
}

enum Gender {
  MALE
  FEMALE
  OTHER
  PREFER_NOT_TO_SAY
}

enum ActivityLevel {
  SEDENTARY
  LIGHTLY_ACTIVE
  MODERATELY_ACTIVE
  VERY_ACTIVE
  EXTRA_ACTIVE
}

enum ExperienceLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

enum ExerciseEnvironment {
  GYM
  HOME
  OUTDOOR
  ANY
}

enum DayOfWeek {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
  SUNDAY
}

enum TrainingGoal {
  HYPERTROPHY
  STRENGTH
  POWERBUILDING
  FAT_LOSS
  MAINTENANCE
}
